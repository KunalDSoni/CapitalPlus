<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>About Capital Plus - Modern HR & Payroll Platform in India</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --purple: #7C3AED;
            --purple-d: #6D28D9;
            --purple-dd: #5B21B6;
            --purple-l: #8B5CF6;
            --purple-bg: #F5F3FF;
            --purple-100: #EDE9FE;
            --purple-200: #DDD6FE;
            --text: #0F172A;
            --text-2: #475569;
            --text-3: #94A3B8;
            --border: #E2E8F0;
            --bg-dark: #0F172A;
            --bg-darker: #1E1B4B;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            color: var(--text);
            background: white;
            line-height: 1.6;
        }

        /* ========== NAVBAR — Wise-style bold ========== */
        .nav {
            position: sticky;
            top: 0;
            z-index: 999;
            background: #fff;
            border-bottom: 1px solid var(--border);
            transition: box-shadow .3s cubic-bezier(.4,0,.2,1);
        }
        .nav.scrolled { box-shadow: 0 1px 12px rgba(0,0,0,.06); }
        .nav-inner {
            max-width: 1320px;
            width: 100%;
            margin: 0 auto;
            padding: 0 40px;
            display: flex;
            align-items: center;
            height: 64px;
        }
        .logo {
            font-size: 1.4rem;
            font-weight: 900;
            letter-spacing: -0.04em;
            margin-right: 48px;
            text-decoration: none;
            white-space: nowrap;
        }
        .logo .c { color: var(--purple); }
        .logo .p { color: var(--text); }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 0;
            height: 100%;
            list-style: none;
        }
        .nav-links > li {
            height: 100%;
            display: flex;
            align-items: center;
            position: relative;
        }
        .nav-links > li > a {
            display: flex;
            align-items: center;
            gap: 5px;
            padding: 0 18px;
            height: 100%;
            font-size: .82rem;
            font-weight: 700;
            letter-spacing: .05em;
            text-transform: uppercase;
            color: var(--text-2);
            text-decoration: none;
            transition: color .2s cubic-bezier(.4,0,.2,1);
            border-bottom: 3px solid transparent;
            margin-bottom: -1px;
        }
        .nav-links > li > a:hover { color: var(--text); }
        .nav-links > li > a.active { color: var(--purple); border-bottom-color: var(--purple); }
        .nav-links > li > a svg.chevron { width: 10px; height: 10px; transition: transform .2s; stroke: currentColor; fill: none; stroke-width: 2.5; }
        .nav-links > li:hover > a svg.chevron { transform: rotate(180deg); }

        .dd-menu {
            position: absolute;
            top: 100%;
            left: 0;
            min-width: 210px;
            padding: 6px 0;
            background: #fff;
            border: 1px solid var(--border);
            border-radius: 10px;
            box-shadow: 0 12px 40px rgba(0,0,0,.1);
            opacity: 0;
            visibility: hidden;
            transform: translateY(6px);
            transition: all .2s cubic-bezier(.4,0,.2,1);
            pointer-events: none;
        }
        .nav-links > li:hover > .dd-menu { opacity: 1; visibility: visible; transform: translateY(0); pointer-events: auto; }
        .dd-menu a {
            display: block;
            padding: 10px 20px;
            font-size: .88rem;
            font-weight: 500;
            color: var(--text-2);
            text-decoration: none;
            transition: all .15s cubic-bezier(.4,0,.2,1);
        }
        .dd-menu a:hover { background: var(--purple-bg); color: var(--purple); padding-left: 24px; }
        .dd-sep { height: 1px; background: var(--border); margin: 4px 12px; }

        .nav-right {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-left: auto;
        }
        .btn-ghost {
            display: inline-flex;
            align-items: center;
            padding: 9px 16px;
            background: transparent;
            border: none;
            color: var(--text-2);
            font-weight: 700;
            font-size: .84rem;
            cursor: pointer;
            transition: all .2s;
            font-family: inherit;
            border-radius: 8px;
        }
        .btn-ghost:hover { color: var(--purple); }
        .btn-primary {
            display: inline-flex;
            align-items: center;
            padding: 9px 22px;
            background: var(--purple);
            color: white;
            border: none;
            border-radius: 8px;
            font-weight: 700;
            font-size: .84rem;
            cursor: pointer;
            transition: all .2s;
            font-family: inherit;
            box-shadow: 0 2px 8px rgba(124,58,237,.25);
            text-decoration: none;
        }
        .btn-primary:hover { background: var(--purple-d); transform: translateY(-1px); box-shadow: 0 4px 16px rgba(124,58,237,.35); }

        .hamburger {
            display: none;
            flex-direction: column;
            gap: 5px;
            background: none;
            border: none;
            cursor: pointer;
            margin-left: auto;
        }
        .hamburger span {
            width: 20px;
            height: 2px;
            background: var(--text);
            border-radius: 2px;
            transition: .3s cubic-bezier(.4,0,.2,1);
        }

        /* ========== HERO ========== */
        .hero {
            background: linear-gradient(135deg, var(--purple-bg) 0%, white 100%);
            padding: 6rem 2rem;
            text-align: center;
            overflow: hidden;
            position: relative;
        }

        .hero::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -20%;
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, rgba(124, 58, 237, 0.1) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
        }

        .hero::after {
            content: '';
            position: absolute;
            bottom: -30%;
            left: -15%;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(139, 92, 246, 0.08) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
        }

        .hero-content {
            max-width: 800px;
            margin: 0 auto;
            position: relative;
            z-index: 1;
            opacity: 0;
            animation: slideInUp 0.8s cubic-bezier(0.4, 0, 0.2, 1) forwards;
        }

        @keyframes slideInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .hero h1 {
            font-size: 3.5rem;
            font-weight: 900;
            line-height: 1.2;
            margin-bottom: 1rem;
            background: linear-gradient(135deg, var(--purple) 0%, var(--purple-l) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .hero p {
            font-size: 1.2rem;
            color: var(--text-2);
            margin-bottom: 2rem;
            line-height: 1.8;
        }

        .hero-scroll {
            margin-top: 3rem;
            animation: float 3s ease-in-out infinite;
        }

        @keyframes float {
            0%, 100% {
                transform: translateY(0px);
            }
            50% {
                transform: translateY(10px);
            }
        }

        .scroll-indicator {
            display: inline-flex;
            flex-direction: column;
            align-items: center;
            gap: 0.5rem;
            color: var(--text-3);
            font-size: 0.85rem;
            font-weight: 500;
        }

        .scroll-indicator svg {
            width: 20px;
            height: 20px;
            stroke: currentColor;
            stroke-width: 2;
            fill: none;
        }

        /* ========== OUR STORY ========== */
        .our-story {
            padding: 6rem 2rem;
            max-width: 1200px;
            margin: 0 auto;
        }

        .story-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
            align-items: center;
        }

        .story-content h2 {
            font-size: 2.5rem;
            font-weight: 900;
            margin-bottom: 1.5rem;
            color: var(--text);
        }

        .story-content p {
            font-size: 1.05rem;
            color: var(--text-2);
            margin-bottom: 1.25rem;
            line-height: 1.8;
        }

        .story-image {
            position: relative;
            height: 400px;
            border-radius: 16px;
            overflow: hidden;
            background: linear-gradient(135deg, var(--purple-bg) 0%, var(--purple-100) 100%);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .story-image svg {
            width: 80%;
            height: 80%;
            opacity: 0;
            animation: fadeInScale 0.8s cubic-bezier(0.4, 0, 0.2, 1) 0.3s forwards;
        }

        @keyframes fadeInScale {
            from {
                opacity: 0;
                transform: scale(0.9);
            }
            to {
                opacity: 1;
                transform: scale(1);
            }
        }

        /* ========== OUR MISSION ========== */
        .our-mission {
            padding: 6rem 2rem;
            max-width: 1200px;
            margin: 0 auto;
        }

        .mission-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
            align-items: center;
        }

        .mission-grid .mission-image {
            order: -1;
        }

        .mission-content h2 {
            font-size: 2.5rem;
            font-weight: 900;
            margin-bottom: 1.5rem;
            color: var(--text);
        }

        .mission-content p {
            font-size: 1.05rem;
            color: var(--text-2);
            margin-bottom: 1.25rem;
            line-height: 1.8;
        }

        .mission-image {
            position: relative;
            height: 400px;
            border-radius: 16px;
            overflow: hidden;
            background: linear-gradient(135deg, var(--purple-l) 0%, var(--purple) 100%);
            opacity: 0.9;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .mission-image svg {
            width: 80%;
            height: 80%;
            opacity: 0;
            animation: fadeInScale 0.8s cubic-bezier(0.4, 0, 0.2, 1) 0.3s forwards;
        }

        /* ========== STATS ========== */
        .stats {
            background: linear-gradient(135deg, var(--bg-dark) 0%, var(--bg-darker) 100%);
            padding: 6rem 2rem;
            position: relative;
            overflow: hidden;
        }

        .stats::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -20%;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(124, 58, 237, 0.15) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
        }

        .stats-container {
            max-width: 1200px;
            margin: 0 auto;
            position: relative;
            z-index: 1;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 2rem;
        }

        .stat-card {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 16px;
            padding: 2.5rem 2rem;
            text-align: center;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            opacity: 0;
            animation: slideUp 0.6s cubic-bezier(0.4, 0, 0.2, 1) forwards;
        }

        .stat-card:nth-child(1) { animation-delay: 0.1s; }
        .stat-card:nth-child(2) { animation-delay: 0.2s; }
        .stat-card:nth-child(3) { animation-delay: 0.3s; }
        .stat-card:nth-child(4) { animation-delay: 0.4s; }

        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .stat-card:hover {
            background: rgba(255, 255, 255, 0.08);
            border-color: rgba(124, 58, 237, 0.3);
            transform: translateY(-8px);
        }

        .stat-number {
            font-size: 2.5rem;
            font-weight: 900;
            background: linear-gradient(135deg, var(--purple) 0%, #EC4899 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 0.5rem;
        }

        .stat-label {
            color: rgba(255, 255, 255, 0.8);
            font-size: 1rem;
            font-weight: 600;
            letter-spacing: 0.5px;
        }

        /* ========== CORE VALUES ========== */
        .values {
            padding: 6rem 2rem;
            max-width: 1200px;
            margin: 0 auto;
        }

        .values h2 {
            font-size: 2.5rem;
            font-weight: 900;
            text-align: center;
            margin-bottom: 4rem;
            color: var(--text);
        }

        .values-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 2rem;
        }

        .value-card {
            padding: 2.5rem 2rem;
            border-radius: 16px;
            background: white;
            border: 2px solid var(--border);
            position: relative;
            overflow: hidden;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .value-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, var(--purple), var(--purple-l));
            transform: scaleX(0);
            transform-origin: left;
            transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .value-card:hover {
            border-color: var(--purple);
            transform: translateY(-8px);
        }

        .value-card:hover::before {
            transform: scaleX(1);
        }

        .value-icon {
            width: 56px;
            height: 56px;
            background: var(--purple-bg);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 1.5rem;
            font-size: 1.75rem;
        }

        .value-card h3 {
            font-size: 1.25rem;
            font-weight: 700;
            margin-bottom: 0.75rem;
            color: var(--text);
        }

        .value-card p {
            color: var(--text-2);
            line-height: 1.6;
            font-size: 0.95rem;
        }

        /* ========== PARTNERSHIP ========== */
        .partnership {
            margin: 4rem 2rem;
            padding: 3rem;
            border-radius: 16px;
            background: white;
            border-left: 6px solid var(--purple);
            max-width: 1200px;
            margin-left: auto;
            margin-right: auto;
            box-shadow: 0 4px 20px rgba(124, 58, 237, 0.08);
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .partnership:hover {
            box-shadow: 0 8px 32px rgba(124, 58, 237, 0.12);
            transform: translateY(-4px);
        }

        .partnership h3 {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 1rem;
        }

        .partnership p {
            color: var(--text-2);
            line-height: 1.8;
            font-size: 1.05rem;
        }

        /* ========== CTA BANNER ========== */
        .cta-banner {
            margin: 4rem 2rem;
            padding: 4rem 3rem;
            border-radius: 20px;
            background: linear-gradient(135deg, var(--purple) 0%, var(--purple-l) 100%);
            color: white;
            text-align: center;
            max-width: 1200px;
            margin-left: auto;
            margin-right: auto;
            box-shadow: 0 20px 40px rgba(124, 58, 237, 0.3);
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .cta-banner:hover {
            transform: translateY(-4px);
            box-shadow: 0 24px 48px rgba(124, 58, 237, 0.4);
        }

        .cta-banner h2 {
            font-size: 2rem;
            font-weight: 900;
            margin-bottom: 1.5rem;
        }

        .cta-buttons {
            display: flex;
            gap: 1rem;
            justify-content: center;
            flex-wrap: wrap;
        }

        .btn-white {
            background: white;
            color: var(--purple);
            padding: 0.875rem 2rem;
            border: none;
            border-radius: 8px;
            font-weight: 700;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .btn-white:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15);
        }

        .btn-outline {
            background: transparent;
            color: white;
            padding: 0.875rem 2rem;
            border: 2px solid white;
            border-radius: 8px;
            font-weight: 700;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .btn-outline:hover {
            background: white;
            color: var(--purple);
            transform: translateY(-2px);
        }

        /* ========== FOOTER ========== */
        footer {
            background: linear-gradient(135deg, var(--bg-dark) 0%, var(--bg-darker) 100%);
            color: rgba(255, 255, 255, 0.8);
            padding: 4rem 2rem 2rem;
            margin-top: 6rem;
        }

        .footer-container {
            max-width: 1200px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 3rem;
            margin-bottom: 3rem;
        }

        .footer-section h4 {
            color: white;
            font-size: 1rem;
            font-weight: 700;
            margin-bottom: 1.5rem;
            letter-spacing: 0.5px;
        }

        .footer-section a {
            display: block;
            color: rgba(255, 255, 255, 0.7);
            text-decoration: none;
            margin-bottom: 0.75rem;
            font-size: 0.95rem;
            transition: color 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .footer-section a:hover {
            color: var(--purple-l);
        }

        .footer-bottom {
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            padding-top: 2rem;
            text-align: center;
            font-size: 0.9rem;
            color: rgba(255, 255, 255, 0.6);
        }

        /* ========== SCROLL REVEAL ========== */
        .reveal {
            opacity: 0;
            transform: translateY(30px);
            transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }

        /* ========== MOBILE RESPONSIVE ========== */
        @media (max-width: 1024px) {
            .story-grid,
            .mission-grid,
            .stats-grid,
            .values-grid {
                grid-template-columns: 1fr;
            }

            .mission-grid .mission-image {
                order: 0;
            }

            .hero h1 {
                font-size: 2.5rem;
            }

            .story-image,
            .mission-image {
                height: 300px;
            }

            .values-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .footer-container {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (max-width: 768px) {
            .nav-inner { padding: 0 20px; }
            .nav-links, .nav-right { display: none; }
            .hamburger { display: flex; }
            .nav.open .nav-links {
                display: flex;
                flex-direction: column;
                position: absolute;
                top: 64px;
                left: 0;
                right: 0;
                background: #fff;
                height: auto;
                padding: 12px 20px;
                box-shadow: 0 12px 40px rgba(0,0,0,.1);
                border-bottom: 1px solid var(--border);
            }
            .nav.open .nav-links > li { height: auto; }
            .nav.open .nav-links > li > a { height: auto; padding: 10px 0; border-bottom: none; margin-bottom: 0; text-transform: none; letter-spacing: 0; font-size: .95rem; }
            .nav.open .nav-right {
                display: flex;
                position: absolute;
                left: 0;
                right: 0;
                background: #fff;
                padding: 8px 20px 16px;
            }
            .nav.open .nav-right .btn-ghost, .nav.open .nav-right .btn-primary { flex: 1; text-align: center; }
            .dd-menu { position: static; opacity: 1; visibility: visible; transform: none; box-shadow: none; border: none; pointer-events: auto; padding: 0 0 0 16px; min-width: auto; border-radius: 0; }
            .dd-sep { display: none; }

            .hero {
                padding: 4rem 1.5rem;
            }

            .hero h1 {
                font-size: 2rem;
            }

            .hero p {
                font-size: 1rem;
            }

            .our-story,
            .our-mission,
            .values {
                padding: 4rem 1.5rem;
            }

            .story-content h2,
            .mission-content h2,
            .values h2 {
                font-size: 1.75rem;
            }

            .story-grid,
            .mission-grid {
                gap: 2rem;
            }

            .values-grid {
                grid-template-columns: 1fr;
                gap: 1.5rem;
            }

            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .cta-banner {
                margin: 2rem 1.5rem;
                padding: 2.5rem 1.5rem;
            }

            .cta-banner h2 {
                font-size: 1.5rem;
            }

            .cta-buttons {
                flex-direction: column;
            }

            .btn-white,
            .btn-outline {
                width: 100%;
            }

            .partnership {
                margin: 2rem 1.5rem;
                padding: 2rem 1.5rem;
            }

            .footer-container {
                grid-template-columns: 1fr;
                gap: 2rem;
            }
        }

        @media (max-width: 640px) {
            .hero {
                padding: 3rem 1rem;
            }

            .hero h1 {
                font-size: 1.75rem;
            }

            .our-story,
            .our-mission {
                padding: 3rem 1rem;
            }

            .stat-number {
                font-size: 2rem;
            }

            .stats-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <!-- NAVBAR -->
    <nav class="nav" id="mainNav">
        <div class="nav-inner">
            <a href="index.html" class="logo"><span class="c">Capital</span><span class="p">Plus</span></a>
            <button class="hamburger" id="hamburger" aria-label="Menu"><span></span><span></span><span></span></button>
            <ul class="nav-links" id="navLinks">
                <li><a href="index.html">Home</a></li>
                <li><a href="about.html" class="active">The Company</a></li>
                <li>
                    <a href="#">Services <svg class="chevron" viewBox="0 0 10 10"><path d="M2 3.5l3 3 3-3"/></svg></a>
