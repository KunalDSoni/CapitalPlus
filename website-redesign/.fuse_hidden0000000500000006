      </div>
    </div>
  </nav>

  <!-- HERO SECTION -->
  <section class="hero">
    <h1>Let's Talk</h1>
    <p>Have questions about Capital Plus? We'd love to hear from you. Reach out and let's discuss how we can help transform your HR operations.</p>
  </section>

  <!-- CONTACT SECTION -->
  <section class="contact-section">
    <!-- FORM -->
    <div class="contact-form-wrapper">
      <h2 class="contact-form-title">Send us a message</h2>
      <form id="contactForm">
        <div class="form-group">
          <input type="text" class="form-input" placeholder="Full Name" required>
          <input type="email" class="form-input" placeholder="Email Address" required>
        </div>
        <div class="form-group">
          <input type="tel" class="form-input" placeholder="Phone Number" required>
          <input type="text" class="form-input" placeholder="Company Name" required>
        </div>
        <div class="form-group full">
          <select class="form-select" required>
            <option value="" disabled selected>Select a Service</option>
            <option value="payroll">Payroll Management</option>
            <option value="staffing">Staffing Solutions</option>
            <option value="compliance">Compliance & Legal</option>
            <option value="general">General Inquiry</option>
            <option value="partnership">Partnership Opportunity</option>
          </select>
        </div>
        <div class="form-group full">
          <textarea class="form-textarea" placeholder="Tell us more about your needs..." required></textarea>
        </div>
        <button type="submit" class="form-submit">Send Message</button>
        <p id="formStatus" style="text-align: center; margin-top: 1rem; font-size: 0.9rem; color: var(--text-2); display: none;"></p>
      </form>
    </div>

    <!-- CONTACT INFO -->
    <div class="contact-info">
      <div>
        <h2 class="contact-info-title">Get in Touch</h2>
      </div>
      <div class="info-card">
        <div class="info-card-label">📍 Office Address</div>
        <div class="info-card-value">37 Baleshwar Gold<br>Ahmedabad, India</div>
      </div>
      <div class="info-card">
        <div class="info-card-label">✉️ Email</div>
        <div class="info-card-value">
          <a href="mailto:info@capitalplusonline.in">info@capitalplusonline.in</a>
        </div>
      </div>
      <div class="info-card">
        <div class="info-card-label">📞 Phone</div>
        <div class="info-card-value">Available upon inquiry<br><a href="#contactForm">Schedule a call</a></div>
      </div>
      <div class="info-card">
        <div class="info-card-label">🕒 Business Hours</div>
        <div class="info-card-value">Monday – Saturday<br>9:00 AM – 6:00 PM IST</div>
      </div>
      <div class="map-placeholder">
        📍 Map coming soon — 37 Baleshwar Gold, Ahmedabad
      </div>
    </div>
  </section>

  <!-- CTA BANNER -->
  <section class="cta-banner">
    <h2>Prefer a Quick Call?</h2>
    <p>Our team is ready to discuss your HR & Payroll needs. Schedule a demo or consultation today.</p>
    <button class="cta-btn" onclick="scrollToForm()">Get in Touch</button>
  </section>

  <!-- FOOTER -->
  <footer>
    <div class="footer-container">
      <div class="footer-section">
        <h3>Capital Plus</h3>
        <p>Modern HR & Payroll platform designed for Indian businesses. Simplify operations, ensure compliance, and focus on growth.</p>
      </div>
      <div class="footer-section">
        <h3>Product</h3>
        <ul>
          <li><a href="payroll.html">Payroll Management</a></li>
          <li><a href="staffing.html">Staffing Solutions</a></li>
          <li><a href="compliance.html">Compliance</a></li>
          <li><a href="#">Pricing</a></li>
        </ul>
      </div>
      <div class="footer-section">
        <h3>Company</h3>
        <ul>
          <li><a href="about.html">About Us</a></li>
          <li><a href="contact.html">Contact</a></li>
          <li><a href="#">Blog</a></li>
          <li><a href="#">Careers</a></li>
        </ul>
      </div>
      <div class="footer-section">
        <h3>Legal</h3>
        <ul>
          <li><a href="#">Privacy Policy</a></li>
          <li><a href="#">Terms of Service</a></li>
          <li><a href="#">Cookie Policy</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; 2026 Capital Plus. All rights reserved. | Built for Indian businesses, by design.</p>
    </div>
  </footer>

  <!-- JAVASCRIPT -->
  <script>
    const hamburger = document.getElementById('hamburger');
    const mainNav = document.getElementById('mainNav');
    hamburger.addEventListener('click', () => mainNav.classList.toggle('open'));
    window.addEventListener('scroll', () => mainNav.classList.toggle('scrolled', window.scrollY > 20));

    // Form Submission Handler
    const contactForm = document.getElementById('contactForm');
    const formStatus = document.getElementById('formStatus');

    contactForm.addEventListener('submit', (e) => {
      e.preventDefault();

      const formData = {
        name: contactForm.querySelector('input[placeholder="Full Name"]').value,
        email: contactForm.querySelector('input[placeholder="Email Address"]').value,
        phone: contactForm.querySelector('input[placeholder="Phone Number"]').value,
        company: contactForm.querySelector('input[placeholder="Company Name"]').value,
        service: contactForm.querySelector('select').value,
        message: contactForm.querySelector('textarea').value,
        timestamp: new Date().toISOString()
      };

      console.log('Form submitted:', formData);

      // Show success message
      const submitBtn = contactForm.querySelector('.form-submit');
      const originalText = submitBtn.textContent;
      submitBtn.textContent = '✓ Message Sent!';
      submitBtn.classList.add('success');

      formStatus.style.display = 'block';
      formStatus.textContent = 'Thank you for reaching out! We will get back to you shortly.';
      formStatus.style.color = '#10B981';

      // Reset form
      contactForm.reset();

      // Reset button after 3 seconds
      setTimeout(() => {
        submitBtn.textContent = originalText;
        submitBtn.classList.remove('success');
        formStatus.style.display = 'none';
      }, 3000);
    });

    // Scroll to form function
    function scrollToForm() {
      document.querySelector('.contact-form-wrapper').scrollIntoView({ behavior: 'smooth' });
    }
  </script>
</body>
