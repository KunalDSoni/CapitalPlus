<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Compliance Solutions - Capital Plus</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            color: #0F172A;
            background-color: #F5F3FF;
            scroll-behavior: smooth;
        }

        /* NAVBAR — Wise-style */
        .nav{position:sticky;top:0;z-index:1000;background:#fff;border-bottom:1px solid #E2E8F0;transition:box-shadow .3s cubic-bezier(.4,0,.2,1)}
        .nav.scrolled{box-shadow:0 1px 12px rgba(0,0,0,.06)}
        .nav-inner{max-width:1320px;width:100%;margin:0 auto;padding:0 40px;display:flex;align-items:center;height:64px}
        .logo{font-size:1.4rem;font-weight:900;letter-spacing:-.04em;margin-right:40px;white-space:nowrap;text-decoration:none}
        .logo .c{color:#7C3AED}.logo .p{color:#0F172A}
        .nav-links{display:flex;align-items:center;gap:4px;height:100%;margin:0;padding:0;list-style:none}
        .nav-links>li{height:100%;display:flex;align-items:center;position:relative}
        .nav-links>li>a{display:flex;align-items:center;gap:5px;padding:6px 14px;height:auto;font-size:.92rem;font-weight:500;color:#0F172A;transition:all .15s;border-radius:100px;border:1.5px solid transparent;text-decoration:none}
        .nav-links>li>a:hover{background:#F5F3FF}
        .nav-links>li>a.active{border-color:#0F172A;background:transparent}
        .nav-links>li>a svg.chev{width:10px;height:10px;stroke:currentColor;fill:none;stroke-width:2;transition:transform .2s}
        .nav-links>li:hover>a svg.chev{transform:rotate(180deg)}
        .mega-dd{position:fixed;top:64px;left:0;right:0;background:#fff;border-bottom:1px solid #E2E8F0;box-shadow:0 16px 48px rgba(0,0,0,.08);opacity:0;visibility:hidden;transform:translateY(-4px);transition:all .2s cubic-bezier(.4,0,.2,1);pointer-events:none}
        .nav-links>li:hover>.mega-dd{opacity:1;visibility:visible;transform:translateY(0);pointer-events:auto}
        .mega-inner{max-width:1100px;margin:0 auto;padding:40px;display:grid;grid-template-columns:280px 1fr;gap:48px}
        .mega-promo{border-radius:14px;overflow:hidden;background:#F5F3FF;display:flex;flex-direction:column}
        .mega-promo-img{height:140px;background:linear-gradient(135deg,#7C3AED,#8B5CF6);display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,.9);font-size:2.5rem}
        .mega-promo-body{padding:20px}
        .mega-promo-body h3{font-size:1rem;font-weight:800;color:#0F172A;margin-bottom:6px}
        .mega-promo-body p{font-size:.82rem;color:#475569;line-height:1.5;margin-bottom:14px}
        .mega-promo-link{display:inline-flex;align-items:center;gap:4px;font-size:.85rem;font-weight:700;color:#7C3AED;transition:gap .2s;text-decoration:none}
        .mega-promo-link:hover{gap:8px}
        .mega-cols{display:grid;grid-template-columns:1fr 1fr;gap:32px}
        .mega-col-head{font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#94A3B8;margin-bottom:16px}
        .mega-link{display:flex;align-items:center;gap:10px;padding:8px 0;font-size:.92rem;font-weight:500;color:#0F172A;transition:color .15s;text-decoration:none}
        .mega-link:hover{color:#7C3AED}
        .mega-link .ml-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
        .nav-right{display:flex;align-items:center;gap:8px;margin-left:auto}
        .btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;padding:9px 22px;border-radius:100px;font-weight:600;font-size:.88rem;cursor:pointer;border:none;transition:all .2s;font-family:inherit;text-decoration:none}
        .btn-ghost{color:#475569;background:transparent;padding:9px 14px}
        .btn-ghost:hover{color:#0F172A}
        .btn-primary{color:#fff;background:#7C3AED;box-shadow:0 2px 8px rgba(124,58,237,.2)}
        .btn-primary:hover{background:#6D28D9;box-shadow:0 4px 16px rgba(124,58,237,.3)}
        .hamburger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:6px;margin-left:auto}
        .hamburger span{display:block;width:20px;height:2px;background:#0F172A;border-radius:2px;transition:.3s}

        @media (max-width: 768px) {
            .nav-inner{padding:0 20px}
            .nav-links,.nav-right{display:none}
            .hamburger{display:flex}
            .nav.open .nav-links{display:flex;flex-direction:column;position:absolute;top:64px;left:0;right:0;background:#fff;height:auto;padding:12px 20px;box-shadow:0 12px 40px rgba(0,0,0,.1);border-bottom:1px solid #E2E8F0}
            .nav.open .nav-links>li{height:auto}
            .nav.open .nav-links>li>a{height:auto;padding:10px 0;border-bottom:none;margin-bottom:0;text-transform:none;letter-spacing:0;font-size:.95rem}
            .nav.open .nav-right{display:flex;position:absolute;left:0;right:0;background:#fff;padding:8px 20px 16px}
            .nav.open .nav-right .btn{flex:1;text-align:center}
            .mega-dd{position:static;opacity:1;visibility:visible;transform:none;box-shadow:none;border:none;border-bottom:none;pointer-events:auto;width:100%;margin-top:8px}
            .mega-inner{grid-template-columns:1fr;padding:16px 0;gap:16px}
            .mega-promo{display:none}
            .mega-cols{grid-template-columns:1fr;gap:16px}
            .mega-col-head{margin-bottom:8px}
            .mega-link{padding:6px 0}
        }

        /* HERO SECTION */
        .hero {
            background: linear-gradient(135deg, #F5F3FF 0%, #EDE9FE 50%, #DDD6FE 100%);
            padding: 120px 40px;
            text-align: center;
            margin-top: 72px;
            position: relative;
            overflow: hidden;
        }

        .hero::before {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(124, 58, 237, 0.1) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
        }

        .hero::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 300px;
            height: 300px;
            background: radial-gradient(circle, rgba(124, 58, 237, 0.08) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
        }

        .hero-content {
            position: relative;
            z-index: 1;
            animation: slideInDown 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        .hero h1 {
            font-size: 64px;
            font-weight: 800;
            color: #0F172A;
            margin-bottom: 24px;
            letter-spacing: -1.5px;
            line-height: 1.1;
        }

        .hero h1 span {
            background: linear-gradient(135deg, #7C3AED 0%, #6D28D9 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .hero p {
            font-size: 20px;
            color: #6B7280;
            max-width: 700px;
            margin: 0 auto;
            line-height: 1.7;
            font-weight: 500;
        }

        @keyframes slideInDown {
            from {
                opacity: 0;
                transform: translateY(-30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @media (max-width: 1024px) {
            .features-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 24px;
            }

            .benefits-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 30px;
            }

            .split-section {
                grid-template-columns: 1fr;
                gap: 50px;
                padding: 80px 20px;
            }

            .split-image {
                height: 350px;
            }
        }

        @media (max-width: 768px) {
            .hero {
                padding: 60px 20px;
                margin-top: 0;
            }

            .hero h1 {
                font-size: 32px;
                letter-spacing: -0.5px;
            }

            .hero p {
                font-size: 15px;
                line-height: 1.6;
            }

            .features-section {
                padding: 60px 20px;
            }

            .section-title {
                font-size: 32px;
                margin-bottom: 16px;
            }

            .section-subtitle {
                margin-bottom: 40px;
            }

            .features-grid {
                grid-template-columns: 1fr;
                gap: 20px;
            }

            .feature-card {
                padding: 28px;
            }

            .feature-icon {
                width: 56px;
                height: 56px;
                font-size: 28px;
                margin-bottom: 16px;
            }

            .feature-card h3 {
                font-size: 18px;
            }

            .feature-card p {
                font-size: 14px;
            }

            .split-section {
                padding: 60px 20px;
                grid-template-columns: 1fr;
                gap: 50px;
            }

            .split-text h2 {
                font-size: 32px;
                margin-bottom: 20px;
            }

            .split-text p {
                font-size: 16px;
                margin-bottom: 30px;
            }

            .benefits-list li {
                font-size: 14px;
                padding: 12px 0;
                padding-left: 32px;
            }

            .split-image {
                height: 280px;
                font-size: 80px;
            }

            .benefits-section {
                padding: 80px 20px;
            }

            .benefits-grid {
                grid-template-columns: 1fr;
                gap: 20px;
            }

            .benefit-item {
                padding: 28px;
            }

            .benefit-icon {
                width: 64px;
                height: 64px;
                font-size: 32px;
                margin-bottom: 16px;
            }

            .benefit-item h3 {
                font-size: 18px;
            }

            .benefit-item p {
                font-size: 14px;
            }

            .cta-banner {
                padding: 60px 20px;
            }

            .cta-banner h2 {
                font-size: 32px;
                margin-bottom: 12px;
            }

            .cta-banner p {
                font-size: 16px;
            }

            footer {
                padding: 60px 20px;
            }

            .footer-container {
                grid-template-columns: 1fr;
                gap: 40px;
                margin-bottom: 40px;
            }

            .footer-bottom {
                padding-top: 30px;
            }
        }

        /* FEATURES SECTION */
        .features-section {
            padding: 100px 40px;
            background-color: white;
            position: relative;
        }

        .section-title {
            font-size: 48px;
            font-weight: 800;
            color: #0F172A;
            text-align: center;
            margin-bottom: 20px;
            letter-spacing: -1px;
            animation: fadeInUp 0.8s ease 0.2s both;
        }

        .section-subtitle {
            font-size: 18px;
            color: #6B7280;
            text-align: center;
            margin-bottom: 80px;
            max-width: 600px;
            margin-left: auto;
            margin-right: auto;
            animation: fadeInUp 0.8s ease 0.3s both;
        }

        .features-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 32px;
            max-width: 1280px;
            margin: 0 auto;
        }

        .feature-card {
            background: white;
            border: 2px solid #EDE9FE;
            border-radius: 16px;
            padding: 40px;
            transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
            cursor: pointer;
            position: relative;
            overflow: hidden;
            animation: fadeInUp 0.8s ease both;
        }

        .feature-card:nth-child(1) { animation-delay: 0.2s; }
        .feature-card:nth-child(2) { animation-delay: 0.3s; }
        .feature-card:nth-child(3) { animation-delay: 0.4s; }
        .feature-card:nth-child(4) { animation-delay: 0.5s; }
        .feature-card:nth-child(5) { animation-delay: 0.6s; }
        .feature-card:nth-child(6) { animation-delay: 0.7s; }

        .feature-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(124, 58, 237, 0.05), transparent);
            transition: left 0.6s ease;
        }

        .feature-card:hover {
            border-color: #7C3AED;
            transform: translateY(-12px);
            box-shadow: 0 24px 48px rgba(124, 58, 237, 0.15);
        }

        .feature-card:hover::before {
            left: 100%;
        }

        .feature-icon {
            width: 64px;
            height: 64px;
            background: linear-gradient(135deg, #7C3AED 0%, #6D28D9 100%);
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 32px;
            margin-bottom: 24px;
            color: white;
            transition: transform 0.3s ease;
        }

        .feature-card:hover .feature-icon {
            transform: scale(1.1) rotate(5deg);
        }

        .feature-card h3 {
            font-size: 20px;
            font-weight: 700;
            color: #0F172A;
            margin-bottom: 12px;
        }

        .feature-card p {
            font-size: 15px;
            color: #6B7280;
            line-height: 1.7;
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @media (max-width: 1024px) {
            .features-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 24px;
            }
        }

        @media (max-width: 768px) {
            .features-section {
                padding: 80px 20px;
            }

            .section-title {
                font-size: 36px;
                margin-bottom: 16px;
            }

            .section-subtitle {
                margin-bottom: 60px;
            }

            .features-grid {
                grid-template-columns: 1fr;
                gap: 20px;
            }

            .feature-card {
                padding: 28px;
            }
        }

        /* SPLIT SECTION */
        .split-section {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 80px;
            max-width: 1280px;
            margin: 0 auto;
            padding: 100px 40px;
            align-items: center;
        }

        .split-text h2 {
            font-size: 48px;
            font-weight: 800;
            color: #0F172A;
            margin-bottom: 28px;
            letter-spacing: -1px;
            animation: fadeInLeft 0.8s ease 0.2s both;
        }

        .split-text p {
            font-size: 17px;
            color: #6B7280;
            line-height: 1.8;
            margin-bottom: 40px;
            animation: fadeInLeft 0.8s ease 0.3s both;
        }

        .benefits-list {
            list-style: none;
            animation: fadeInLeft 0.8s ease 0.4s both;
        }

        .benefits-list li {
            font-size: 16px;
            color: #0F172A;
            padding: 14px 0;
            padding-left: 36px;
            position: relative;
            font-weight: 500;
            transition: all 0.3s ease;
        }

        .benefits-list li:hover {
            padding-left: 42px;
            color: #7C3AED;
        }

        .benefits-list li:before {
            content: "✓";
            position: absolute;
            left: 0;
            color: white;
            font-weight: 700;
            font-size: 18px;
            width: 24px;
            height: 24px;
            background: linear-gradient(135deg, #7C3AED 0%, #6D28D9 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
        }

        .benefits-list li:hover:before {
            transform: scale(1.15);
        }

        .split-image {
            background: linear-gradient(135deg, #F5F3FF 0%, #EDE9FE 50%, #DDD6FE 100%);
            border-radius: 20px;
            height: 450px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 120px;
            position: relative;
            overflow: hidden;
            animation: fadeInRight 0.8s ease 0.2s both;
            box-shadow: 0 20px 48px rgba(124, 58, 237, 0.12);
        }

        .split-image::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -20%;
            width: 300px;
            height: 300px;
            background: radial-gradient(circle, rgba(124, 58, 237, 0.08), transparent);
            border-radius: 50%;
            animation: float 6s ease-in-out infinite;
        }

        @keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-30px); }
        }

        @keyframes fadeInLeft {
            from {
                opacity: 0;
                transform: translateX(-40px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        @keyframes fadeInRight {
            from {
                opacity: 0;
                transform: translateX(40px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        @media (max-width: 1024px) {
            .split-section {
                grid-template-columns: 1fr;
                gap: 50px;
                padding: 80px 20px;
            }

            .split-image {
                height: 350px;
            }
        }

        @media (max-width: 768px) {
            .split-section {
                padding: 60px 20px;
            }

            .split-text h2 {
                font-size: 32px;
            }

            .split-text p {
                font-size: 16px;
            }

            .split-image {
                height: 280px;
                font-size: 80px;
            }
        }

        /* BENEFITS SECTION */
        .benefits-section {
            background: linear-gradient(135deg, #F5F3FF 0%, #EDE9FE 100%);
            padding: 100px 40px;
            position: relative;
        }

        .benefits-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 40px;
            max-width: 1280px;
            margin: 0 auto;
        }

        .benefit-item {
            background: white;
            border-radius: 16px;
            padding: 40px;
            text-align: center;
            transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
            animation: fadeInUp 0.8s ease both;
            position: relative;
            overflow: hidden;
        }

        .benefit-item:nth-child(1) { animation-delay: 0.2s; }
        .benefit-item:nth-child(2) { animation-delay: 0.3s; }
        .benefit-item:nth-child(3) { animation-delay: 0.4s; }

        .benefit-item::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, #7C3AED, #6D28D9);
            transform: scaleX(0);
            transition: transform 0.4s ease;
            transform-origin: left;
        }

        .benefit-item:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 40px rgba(124, 58, 237, 0.12);
        }

        .benefit-item:hover::before {
            transform: scaleX(1);
        }

        .benefit-icon {
            width: 72px;
            height: 72px;
            background: linear-gradient(135deg, #7C3AED 0%, #6D28D9 100%);
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 36px;
            margin: 0 auto 20px;
            color: white;
            transition: transform 0.3s ease;
        }

        .benefit-item:hover .benefit-icon {
            transform: scale(1.15) rotate(-5deg);
        }

        .benefit-item h3 {
            font-size: 20px;
            font-weight: 700;
            color: #0F172A;
            margin-bottom: 12px;
        }

        .benefit-item p {
            font-size: 15px;
            color: #6B7280;
            line-height: 1.7;
        }

        @media (max-width: 1024px) {
            .benefits-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 30px;
            }
        }

        @media (max-width: 768px) {
            .benefits-section {
                padding: 80px 20px;
            }

            .benefits-grid {
                grid-template-columns: 1fr;
                gap: 20px;
            }

            .benefit-item {
                padding: 28px;
            }
        }

        /* CTA BANNER */
        .cta-banner {
            background: linear-gradient(135deg, #7C3AED 0%, #6D28D9 100%);
            background-attachment: fixed;
            padding: 100px 40px;
            text-align: center;
            color: white;
            position: relative;
            overflow: hidden;
        }

        .cta-banner::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -10%;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
        }

        .cta-banner::after {
            content: '';
            position: absolute;
            bottom: -30%;
            right: -5%;
            width: 350px;
            height: 350px;
            background: radial-gradient(circle, rgba(255, 255, 255, 0.08) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
        }

        .cta-content {
            position: relative;
            z-index: 1;
            animation: fadeInUp 0.8s ease 0.2s both;
        }

        .cta-banner h2 {
            font-size: 52px;
            font-weight: 800;
            margin-bottom: 24px;
            letter-spacing: -1px;
            line-height: 1.2;
        }

        .cta-banner p {
            font-size: 18px;
            margin-bottom: 40px;
            opacity: 0.95;
            max-width: 600px;
            margin-left: auto;
            margin-right: auto;
            font-weight: 500;
        }

        .cta-banner .btn-started {
            background-color: white;
            color: #7C3AED;
            padding: 14px 40px;
            font-size: 16px;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.25);
        }

        .cta-banner .btn-started:hover {
            background-color: #F5F3FF;
            box-shadow: 0 12px 32px rgba(0, 0, 0, 0.3);
        }

        @media (max-width: 768px) {
            .cta-banner {
                padding: 80px 20px;
            }

            .cta-banner h2 {
                font-size: 36px;
            }

            .cta-banner p {
                font-size: 16px;
            }
        }

        /* FOOTER */
        footer {
            background-color: #0F172A;
            color: white;
            padding: 80px 40px;
            position: relative;
        }

        .footer-container {
            max-width: 1280px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 50px;
            margin-bottom: 50px;
        }

        .footer-section h3 {
            font-size: 15px;
