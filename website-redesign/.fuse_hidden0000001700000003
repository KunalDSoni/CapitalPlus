<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Capital Plus — Modern HR & Payroll Platform</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════════════════
   CAPITAL PLUS — World-Class Homepage
   Inspired by Stripe · Novo · Wise
   ═══════════════════════════════════════════════════ */

*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --purple:   #7C3AED;
  --purple-d: #6D28D9;
  --purple-dd:#5B21B6;
  --purple-l: #8B5CF6;
  --purple-ll:#A78BFA;
  --purple-bg:#F5F3FF;
  --purple-100:#EDE9FE;
  --purple-200:#DDD6FE;
  --text:     #0F172A;
  --text-2:   #475569;
  --text-3:   #94A3B8;
  --border:   #E2E8F0;
  --white:    #FFFFFF;
  --glow:     rgba(124,58,237,.35);
  --radius:   16px;
  --radius-s: 10px;
  --shadow:   0 1px 3px rgba(0,0,0,.06), 0 8px 24px rgba(0,0,0,.04);
  --shadow-l: 0 4px 12px rgba(0,0,0,.04), 0 24px 64px rgba(0,0,0,.08);
  --shadow-xl:0 8px 30px rgba(0,0,0,.06), 0 40px 80px rgba(0,0,0,.1);
  --ease:     cubic-bezier(.4,0,.2,1);
  --max-w:    1200px;
}
html{scroll-behavior:smooth;font-size:16px}
body{font-family:'Inter',system-ui,-apple-system,sans-serif;color:var(--text);background:var(--white);line-height:1.6;-webkit-font-smoothing:antialiased;overflow-x:hidden}
a{text-decoration:none;color:inherit}
ul{list-style:none}
img{max-width:100%;display:block}
.container{max-width:var(--max-w);margin:0 auto;padding:0 24px}

/* ── ANIMATED GRADIENT TEXT ── */
@keyframes gradient-shift{
  0%{background-position:0% 50%}
  50%{background-position:100% 50%}
  100%{background-position:0% 50%}
}
.gradient-text{
  background:linear-gradient(135deg,var(--purple),#EC4899,var(--purple-l),var(--purple));
  background-size:300% 300%;
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  background-clip:text;
  animation:gradient-shift 6s ease infinite;
}

/* ── GLOW PULSE ── */
@keyframes glow-pulse{
  0%,100%{box-shadow:0 0 20px var(--glow)}
  50%{box-shadow:0 0 40px var(--glow),0 0 80px rgba(124,58,237,.15)}
}

/* ── FLOAT ── */
@keyframes float{
  0%,100%{transform:translateY(0)}
  50%{transform:translateY(-12px)}
}

/* ── FADE IN UP ── */
@keyframes fadeInUp{
  from{opacity:0;transform:translateY(30px)}
  to{opacity:1;transform:translateY(0)}
}
.animate{opacity:0;transform:translateY(30px);transition:opacity .7s var(--ease),transform .7s var(--ease)}
.animate.visible{opacity:1;transform:translateY(0)}

/* ═══ NAVBAR — Wise-style ═══ */
.nav{
  position:fixed;top:0;left:0;right:0;z-index:1000;
  background:var(--white);
  border-bottom:1px solid var(--border);
  transition:box-shadow .3s var(--ease);
}
.nav.scrolled{box-shadow:0 1px 12px rgba(0,0,0,.06)}
.nav-inner{
  max-width:1320px;width:100%;margin:0 auto;padding:0 40px;
  display:flex;align-items:center;height:64px;
}
.logo{font-size:1.4rem;font-weight:900;letter-spacing:-.04em;margin-right:40px;white-space:nowrap}
.logo .c{color:var(--purple)}.logo .p{color:var(--text)}

/* Nav Links — Wise style: normal case, pill on hover/active */
.nav-links{display:flex;align-items:center;gap:4px;height:100%;margin:0;padding:0}
.nav-links>li{height:100%;display:flex;align-items:center;position:relative}
.nav-links>li>a{
  display:flex;align-items:center;gap:5px;
  padding:6px 14px;height:auto;
  font-size:.92rem;font-weight:500;
  color:var(--text);transition:all .15s var(--ease);
  border-radius:100px;border:1.5px solid transparent;
}
.nav-links>li>a:hover{background:var(--purple-bg)}
.nav-links>li>a.active{border-color:var(--text);background:transparent}
.nav-links>li>a svg.chev{width:10px;height:10px;stroke:currentColor;fill:none;stroke-width:2;transition:transform .2s var(--ease)}
.nav-links>li:hover>a svg.chev{transform:rotate(180deg)}

/* Full-width Wise mega dropdown */
.mega-dd{
  position:fixed;top:64px;left:0;right:0;
  background:var(--white);
  border-bottom:1px solid var(--border);
  box-shadow:0 16px 48px rgba(0,0,0,.08);
  opacity:0;visibility:hidden;transform:translateY(-4px);
  transition:all .2s var(--ease);pointer-events:none;
}
.nav-links>li:hover>.mega-dd{opacity:1;visibility:visible;transform:translateY(0);pointer-events:auto}
.mega-inner{
  max-width:1100px;margin:0 auto;padding:40px;
  display:grid;grid-template-columns:280px 1fr;gap:48px;
}
/* Left: featured promo card */
.mega-promo{
  border-radius:14px;overflow:hidden;background:var(--purple-bg);
  display:flex;flex-direction:column;
}
.mega-promo-img{
  height:140px;background:linear-gradient(135deg,var(--purple),var(--purple-l));
  display:flex;align-items:center;justify-content:center;
  color:rgba(255,255,255,.9);font-size:2.5rem;
}
.mega-promo-body{padding:20px}
.mega-promo-body h3{font-size:1rem;font-weight:800;color:var(--text);margin-bottom:6px}
.mega-promo-body p{font-size:.82rem;color:var(--text-2);line-height:1.5;margin-bottom:14px}
.mega-promo-link{
  display:inline-flex;align-items:center;gap:4px;
  font-size:.85rem;font-weight:700;color:var(--purple);
  transition:gap .2s var(--ease);
}
.mega-promo-link:hover{gap:8px}

/* Right: columns */
.mega-cols{display:grid;grid-template-columns:1fr 1fr;gap:32px}
.mega-col-head{
  font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;
  color:var(--text-3);margin-bottom:16px;
}
.mega-link{
  display:flex;align-items:center;gap:10px;
  padding:8px 0;font-size:.92rem;font-weight:500;color:var(--text);
  transition:color .15s var(--ease);
}
.mega-link:hover{color:var(--purple)}
.mega-link .ml-dot{
  width:8px;height:8px;border-radius:50%;flex-shrink:0;
}

/* Right side */
.nav-right{display:flex;align-items:center;gap:8px;margin-left:auto}
.btn{
  display:inline-flex;align-items:center;justify-content:center;gap:8px;
  padding:9px 22px;border-radius:100px;font-weight:600;font-size:.88rem;
  cursor:pointer;border:none;transition:all .2s var(--ease);font-family:inherit;
}
.btn-ghost{color:var(--text-2);background:transparent;padding:9px 14px}
.btn-ghost:hover{color:var(--text)}
.btn-primary{
  color:var(--white);background:var(--purple);
  box-shadow:0 2px 8px rgba(124,58,237,.2);
}
.btn-primary:hover{background:var(--purple-d);box-shadow:0 4px 16px rgba(124,58,237,.3)}
.btn-lg{padding:13px 30px;font-size:.92rem;border-radius:100px}
.btn-outline{
  color:var(--purple);background:transparent;
  border:1.5px solid rgba(124,58,237,.3);border-radius:100px;
}
.btn-outline:hover{background:var(--purple-bg);border-color:var(--purple)}
.btn-white{
  color:var(--purple);background:var(--white);border-radius:100px;
  box-shadow:0 1px 3px rgba(0,0,0,.1);
}
.btn-white:hover{box-shadow:0 4px 16px rgba(0,0,0,.12)}

/* Hamburger */
.hamburger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:6px;margin-left:auto}
.hamburger span{display:block;width:20px;height:2px;background:var(--text);border-radius:2px;transition:.3s var(--ease)}

/* ═══ HERO ═══ */
.hero{
  position:relative;padding:148px 0 120px;overflow:hidden;
  background:linear-gradient(180deg,var(--purple-bg) 0%,var(--white) 100%);
}
/* Gradient mesh blobs */
.hero::before{
  content:'';position:absolute;top:-200px;right:-100px;
  width:700px;height:700px;border-radius:50%;
  background:radial-gradient(circle,rgba(124,58,237,.12) 0%,transparent 70%);
  filter:blur(40px);pointer-events:none;
}
.hero::after{
  content:'';position:absolute;bottom:-100px;left:-200px;
  width:600px;height:600px;border-radius:50%;
  background:radial-gradient(circle,rgba(236,72,153,.08) 0%,transparent 70%);
  filter:blur(40px);pointer-events:none;
}
.hero-inner{
  position:relative;z-index:1;
  max-width:1320px;margin:0 auto;padding:0 32px;
  display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;
}
.hero-content{max-width:560px}
.hero-badge{
  display:inline-flex;align-items:center;gap:8px;
  padding:6px 14px 6px 6px;border-radius:100px;
  background:var(--white);border:1px solid var(--border);
  font-size:.8rem;font-weight:600;color:var(--text-2);
  margin-bottom:24px;box-shadow:var(--shadow);
}
.hero-badge .dot{
  width:8px;height:8px;border-radius:50%;
  background:linear-gradient(135deg,#22C55E,#16A34A);
  box-shadow:0 0 6px rgba(34,197,94,.4);
}
.hero-badge span{background:var(--purple-bg);padding:2px 10px;border-radius:100px;color:var(--purple);font-size:.75rem}
.hero h1{
  font-size:clamp(2.75rem,5.2vw,4.25rem);font-weight:900;
  line-height:1.08;letter-spacing:-.035em;margin-bottom:24px;
  color:var(--text);
}
.hero-sub{
  font-size:1.15rem;color:var(--text-2);line-height:1.7;
  max-width:480px;margin-bottom:40px;
}
.hero-actions{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:40px}
.hero-social-proof{display:flex;align-items:center;gap:16px}
.avatar-stack{display:flex}
.avatar-stack .av{
  width:36px;height:36px;border-radius:50%;
  border:2.5px solid var(--white);margin-left:-10px;
  display:flex;align-items:center;justify-content:center;
  font-size:.7rem;font-weight:700;color:var(--white);
}
.avatar-stack .av:first-child{margin-left:0}
.hero-social-proof p{font-size:.85rem;color:var(--text-3)}
.hero-social-proof strong{color:var(--text);font-weight:700}

/* Hero Visual — Floating Dashboard */
.hero-visual{position:relative;display:flex;justify-content:center}
.dashboard{
  position:relative;width:100%;max-width:520px;
  background:var(--white);border-radius:20px;
  border:1px solid var(--border);
  box-shadow:var(--shadow-xl);
  overflow:hidden;
  animation:float 6s ease-in-out infinite;
}
.dash-header{
  padding:20px 24px 16px;border-bottom:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;
}
.dash-header h3{font-size:.9rem;font-weight:700;color:var(--text)}
.dash-status{
  display:flex;align-items:center;gap:6px;font-size:.75rem;
  color:#16A34A;font-weight:600;
}
.dash-status::before{content:'';width:7px;height:7px;border-radius:50%;background:#22C55E;box-shadow:0 0 6px rgba(34,197,94,.5)}
.dash-body{padding:24px}
.dash-stats{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:24px}
.dash-stat{
  padding:20px;border-radius:var(--radius-s);
  background:linear-gradient(135deg,var(--purple-bg),var(--white));
  border:1px solid var(--purple-200);
}
.dash-stat label{font-size:.7rem;font-weight:600;text-transform:uppercase;letter-spacing:.06em;color:var(--text-3);display:block;margin-bottom:8px}
.dash-stat .val{font-size:1.6rem;font-weight:800;color:var(--text);letter-spacing:-.02em}
.dash-stat .val .currency{font-size:.9rem;color:var(--text-3);font-weight:600}
.dash-stat .change{font-size:.72rem;color:#16A34A;font-weight:600;margin-top:4px;display:block}
.dash-rows{display:flex;flex-direction:column;gap:10px}
.dash-row{
  display:flex;align-items:center;justify-content:space-between;
  padding:14px 16px;border-radius:var(--radius-s);
  background:var(--white);border:1px solid var(--border);
  transition:all .2s var(--ease);
}
.dash-row:hover{border-color:var(--purple-200);box-shadow:0 2px 8px rgba(124,58,237,.06)}
.dash-row-left{display:flex;align-items:center;gap:12px}
.dash-row-icon{
  width:34px;height:34px;border-radius:8px;
  display:flex;align-items:center;justify-content:center;font-size:.85rem;
}
.dash-row-info p{font-size:.82rem;font-weight:600;color:var(--text)}
.dash-row-info span{font-size:.7rem;color:var(--text-3)}
.dash-row-amount{text-align:right}
.dash-row-amount p{font-size:.85rem;font-weight:700;color:var(--text)}
.dash-row-amount span{font-size:.68rem;font-weight:600}

/* Floating cards around dashboard */
.float-card{
  position:absolute;padding:14px 18px;border-radius:12px;
  background:var(--white);border:1px solid var(--border);
  box-shadow:var(--shadow-l);z-index:2;
  animation:float 5s ease-in-out infinite;
}
.float-card.fc1{top:40px;left:-60px;animation-delay:-.5s}
.float-card.fc2{bottom:60px;right:-50px;animation-delay:-2s}
.float-card .fc-label{font-size:.65rem;text-transform:uppercase;letter-spacing:.06em;color:var(--text-3);font-weight:600;margin-bottom:4px}
.float-card .fc-val{font-size:1.1rem;font-weight:800;color:var(--purple)}
.float-card .fc-sub{font-size:.7rem;color:#16A34A;font-weight:600;margin-top:2px}

/* ═══ LOGOS BAR ═══ */
.logos-bar{
  padding:60px 0;border-bottom:1px solid var(--border);
  text-align:center;overflow:hidden;
}
.logos-bar p{font-size:.78rem;text-transform:uppercase;letter-spacing:.12em;color:var(--text-3);font-weight:600;margin-bottom:32px}
.logos-track{
  display:flex;gap:64px;align-items:center;justify-content:center;
  opacity:.35;filter:grayscale(1);
}
.logos-track svg{height:24px;width:auto}

/* ═══ FEATURES SECTION ═══ */
.features{padding:120px 0;background:var(--white)}
.section-header{text-align:center;max-width:640px;margin:0 auto 72px}
.section-label{
  display:inline-flex;align-items:center;gap:6px;
  padding:6px 14px;border-radius:100px;
  background:var(--purple-bg);border:1px solid var(--purple-200);
  font-size:.75rem;font-weight:700;text-transform:uppercase;
  letter-spacing:.08em;color:var(--purple);margin-bottom:16px;
}
.section-header h2{
  font-size:clamp(2rem,3.5vw,2.75rem);font-weight:800;
  line-height:1.15;letter-spacing:-.025em;margin-bottom:16px;
}
.section-header p{font-size:1.05rem;color:var(--text-2);line-height:1.7;max-width:520px;margin:0 auto}

.features-grid{
  display:grid;grid-template-columns:repeat(3,1fr);gap:24px;
}
.feature-card{
  position:relative;padding:40px 32px;border-radius:var(--radius);
  background:var(--white);border:1px solid var(--border);
  transition:all .35s var(--ease);overflow:hidden;
}
.feature-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:3px;
  background:linear-gradient(90deg,var(--purple),var(--purple-l));
  transform:scaleX(0);transform-origin:left;transition:transform .35s var(--ease);
}
.feature-card:hover{
  border-color:var(--purple-200);
  box-shadow:0 8px 30px rgba(124,58,237,.08),0 2px 8px rgba(0,0,0,.04);
  transform:translateY(-4px);
}
.feature-card:hover::before{transform:scaleX(1)}
.f-icon{
  width:48px;height:48px;border-radius:12px;
  background:linear-gradient(135deg,var(--purple-bg),var(--purple-100));
  display:flex;align-items:center;justify-content:center;margin-bottom:24px;
}
.f-icon svg{width:22px;height:22px;color:var(--purple)}
.feature-card h3{font-size:1.1rem;font-weight:700;margin-bottom:10px;letter-spacing:-.01em}
.feature-card p{font-size:.9rem;color:var(--text-2);line-height:1.65}

/* ═══ SHOWCASE (Stripe-style split) ═══ */
.showcase{padding:120px 0;background:var(--purple-bg)}
.showcase-inner{
  max-width:var(--max-w);margin:0 auto;padding:0 24px;
  display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;
}
.showcase-text .section-label{margin-bottom:16px}
.showcase-text h2{
  font-size:clamp(2rem,3.5vw,2.5rem);font-weight:800;
  line-height:1.15;letter-spacing:-.025em;margin-bottom:20px;
}
.showcase-text>p{font-size:1.05rem;color:var(--text-2);line-height:1.7;margin-bottom:32px}
.check-list{display:flex;flex-direction:column;gap:16px;margin-bottom:36px}
.check-item{display:flex;gap:14px;align-items:flex-start}
.check-icon{
  width:24px;height:24px;border-radius:50%;flex-shrink:0;margin-top:2px;
  background:linear-gradient(135deg,var(--purple),var(--purple-d));
  display:flex;align-items:center;justify-content:center;
}
.check-icon svg{width:12px;height:12px;color:var(--white)}
.check-item p{font-size:.92rem;color:var(--text-2);line-height:1.6}
.check-item strong{color:var(--text);font-weight:600}

.showcase-visual{position:relative}
.showcase-card{
  background:var(--white);border-radius:var(--radius);
  border:1px solid var(--border);box-shadow:var(--shadow-xl);
  overflow:hidden;
}
.sc-header{
  padding:20px 24px;border-bottom:1px solid var(--border);
  display:flex;align-items:center;gap:8px;
}
.sc-dot{width:10px;height:10px;border-radius:50%}
.sc-body{padding:24px}
.sc-row{
  display:flex;align-items:center;justify-content:space-between;
  padding:16px;border-radius:10px;margin-bottom:8px;
  border:1px solid var(--border);transition:all .2s;
}
.sc-row:hover{background:var(--purple-bg);border-color:var(--purple-200)}
.sc-row-left{display:flex;align-items:center;gap:12px}
.sc-row-dot{width:10px;height:10px;border-radius:50%}
.sc-row-text{font-size:.85rem;font-weight:600;color:var(--text)}
.sc-row-text span{display:block;font-size:.72rem;color:var(--text-3);font-weight:400;margin-top:2px}
.sc-row-right{font-size:.88rem;font-weight:700;color:var(--text)}

/* ═══ PROCESS / HOW IT WORKS (Wise-style) ═══ */
.process{padding:120px 0;background:var(--white)}
.process-steps{
  display:grid;grid-template-columns:repeat(4,1fr);gap:0;
  position:relative;
}
.process-steps::before{
  content:'';position:absolute;top:36px;left:calc(12.5% + 24px);right:calc(12.5% + 24px);
  height:2px;background:linear-gradient(90deg,var(--purple-200),var(--purple),var(--purple-200));
  z-index:0;
}
.process-step{text-align:center;position:relative;z-index:1;padding:0 16px}
.step-num{
  width:72px;height:72px;border-radius:50%;margin:0 auto 24px;
  background:linear-gradient(135deg,var(--purple),var(--purple-d));
  display:flex;align-items:center;justify-content:center;
  font-size:1.5rem;font-weight:800;color:var(--white);
  box-shadow:0 4px 20px rgba(124,58,237,.3);
  position:relative;
}
.step-num::after{
  content:'';position:absolute;inset:-4px;border-radius:50%;
  border:2px solid var(--purple-200);
}
.process-step h3{font-size:1.05rem;font-weight:700;margin-bottom:8px}
.process-step p{font-size:.85rem;color:var(--text-2);line-height:1.6}

/* ═══ STATS (Dark section — Stripe-style) ═══ */
.stats{
  padding:100px 0;position:relative;overflow:hidden;
  background:linear-gradient(135deg,#0F172A 0%,#1E1B4B 50%,#0F172A 100%);
}
.stats::before{
  content:'';position:absolute;top:50%;left:50%;
  width:800px;height:800px;border-radius:50%;
  background:radial-gradient(circle,rgba(124,58,237,.2) 0%,transparent 60%);
  transform:translate(-50%,-50%);pointer-events:none;
}
.stats-inner{
  position:relative;z-index:1;
  max-width:var(--max-w);margin:0 auto;padding:0 24px;
}
.stats-header{text-align:center;margin-bottom:64px}
.stats-header h2{font-size:clamp(2rem,3.5vw,2.75rem);font-weight:800;color:var(--white);line-height:1.15;letter-spacing:-.025em}
.stats-header p{font-size:1.05rem;color:rgba(255,255,255,.5);margin-top:12px}
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:24px}
.stat-card{
  text-align:center;padding:40px 24px;border-radius:var(--radius);
  background:rgba(255,255,255,.04);
  border:1px solid rgba(255,255,255,.08);
  backdrop-filter:blur(10px);
  transition:all .35s var(--ease);
}
.stat-card:hover{
  background:rgba(255,255,255,.08);
  border-color:rgba(124,58,237,.4);
  transform:translateY(-4px);
}
.stat-card .number{
  font-size:clamp(2.2rem,4vw,3rem);font-weight:900;
  background:linear-gradient(135deg,var(--purple-l),#EC4899);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
