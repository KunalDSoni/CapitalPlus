<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Staffing Solutions - Capital Plus</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            color: #0F172A;
            line-height: 1.6;
            background: #F5F3FF;
        }

        /* NAVBAR — Wise-style */
        .nav{position:sticky;top:0;z-index:1000;background:#fff;border-bottom:1px solid #E2E8F0;transition:box-shadow .3s cubic-bezier(.4,0,.2,1)}
        .nav.scrolled{box-shadow:0 1px 12px rgba(0,0,0,.06)}
        .nav-inner{max-width:1320px;width:100%;margin:0 auto;padding:0 40px;display:flex;align-items:center;height:64px}
        .logo{font-size:1.4rem;font-weight:900;letter-spacing:-.04em;margin-right:40px;white-space:nowrap;text-decoration:none}
        .logo .c{color:#7C3AED}.logo .p{color:#0F172A}
        .nav-links{display:flex;align-items:center;gap:4px;height:100%;margin:0;padding:0;list-style:none}
        .nav-links>li{height:100%;display:flex;align-items:center;position:relative}
        .nav-links>li>a{display:flex;align-items:center;gap:5px;padding:6px 14px;height:auto;font-size:.92rem;font-weight:500;color:#0F172A;transition:all .15s;border-radius:100px;border:1.5px solid transparent;text-decoration:none}
        .nav-links>li>a:hover{background:#F5F3FF}
        .nav-links>li>a.active{border-color:#0F172A;background:transparent}
        .nav-links>li>a svg.chev{width:10px;height:10px;stroke:currentColor;fill:none;stroke-width:2;transition:transform .2s}
        .nav-links>li:hover>a svg.chev{transform:rotate(180deg)}
        .mega-dd{position:fixed;top:64px;left:0;right:0;background:#fff;border-bottom:1px solid #E2E8F0;box-shadow:0 16px 48px rgba(0,0,0,.08);opacity:0;visibility:hidden;transform:translateY(-4px);transition:all .2s cubic-bezier(.4,0,.2,1);pointer-events:none}
        .nav-links>li:hover>.mega-dd{opacity:1;visibility:visible;transform:translateY(0);pointer-events:auto}
        .mega-inner{max-width:1100px;margin:0 auto;padding:40px;display:grid;grid-template-columns:280px 1fr;gap:48px}
        .mega-promo{border-radius:14px;overflow:hidden;background:#F5F3FF;display:flex;flex-direction:column}
        .mega-promo-img{height:140px;background:linear-gradient(135deg,#7C3AED,#8B5CF6);display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,.9);font-size:2.5rem}
        .mega-promo-body{padding:20px}
        .mega-promo-body h3{font-size:1rem;font-weight:800;color:#0F172A;margin-bottom:6px}
        .mega-promo-body p{font-size:.82rem;color:#475569;line-height:1.5;margin-bottom:14px}
        .mega-promo-link{display:inline-flex;align-items:center;gap:4px;font-size:.85rem;font-weight:700;color:#7C3AED;transition:gap .2s;text-decoration:none}
        .mega-promo-link:hover{gap:8px}
        .mega-cols{display:grid;grid-template-columns:1fr 1fr;gap:32px}
        .mega-col-head{font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#94A3B8;margin-bottom:16px}
        .mega-link{display:flex;align-items:center;gap:10px;padding:8px 0;font-size:.92rem;font-weight:500;color:#0F172A;transition:color .15s;text-decoration:none}
        .mega-link:hover{color:#7C3AED}
        .mega-link .ml-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
        .nav-right{display:flex;align-items:center;gap:8px;margin-left:auto}
        .btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;padding:9px 22px;border-radius:100px;font-weight:600;font-size:.88rem;cursor:pointer;border:none;transition:all .2s;font-family:inherit;text-decoration:none}
        .btn-ghost{color:#475569;background:transparent;padding:9px 14px}
        .btn-ghost:hover{color:#0F172A}
        .btn-primary{color:#fff;background:#7C3AED;box-shadow:0 2px 8px rgba(124,58,237,.2)}
        .btn-primary:hover{background:#6D28D9;box-shadow:0 4px 16px rgba(124,58,237,.3)}
        .hamburger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:6px;margin-left:auto}
        .hamburger span{display:block;width:20px;height:2px;background:#0F172A;border-radius:2px;transition:.3s}

        /* ===== HERO SECTION ===== */
        .hero {
            max-width: 1200px;
            margin: 0 auto;
            padding: 6rem 2rem 4rem;
            text-align: center;
            animation: fadeInDown 0.8s ease;
        }

        @keyframes fadeInDown {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .section-label {
            font-size: 0.75rem;
            font-weight: 700;
            color: #7C3AED;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            margin-bottom: 1.5rem;
            display: inline-block;
            background: linear-gradient(135deg, rgba(124, 58, 237, 0.1), rgba(109, 40, 217, 0.1));
            padding: 0.5rem 1rem;
            border-radius: 6px;
        }

        .hero h1 {
            font-size: 3.5rem;
            font-weight: 800;
            color: #0F172A;
            margin-bottom: 1rem;
            line-height: 1.2;
            letter-spacing: -1px;
        }

        .hero h1 span {
            background: linear-gradient(135deg, #7C3AED 0%, #6D28D9 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .hero p {
            font-size: 1.125rem;
            color: #475569;
            max-width: 700px;
            margin: 0 auto;
            line-height: 1.8;
            font-weight: 400;
        }

        /* ===== TABS SECTION ===== */
        .tabs-section {
            max-width: 1200px;
            margin: 5rem auto;
            padding: 0 2rem;
        }

        .tabs-header {
            text-align: center;
            margin-bottom: 3.5rem;
        }

        .tabs-header h2 {
            font-size: 2.5rem;
            font-weight: 800;
            margin-bottom: 0.5rem;
            color: #0F172A;
        }

        .tabs-container {
            display: flex;
            gap: 0;
            border-bottom: 2px solid #E9D5FF;
            margin-bottom: 3rem;
            justify-content: center;
        }

        .tab-button {
            padding: 1.25rem 2.5rem;
            background: none;
            border: none;
            cursor: pointer;
            font-size: 1rem;
            font-weight: 600;
            color: #94A3B8;
            border-bottom: 3px solid transparent;
            transition: all 0.3s ease;
            margin-bottom: -2px;
            position: relative;
        }

        .tab-button.active {
            color: #7C3AED;
            border-bottom-color: #7C3AED;
        }

        .tab-button:hover {
            color: #7C3AED;
        }

        .tab-content {
            display: none;
        }

        .tab-content.active {
            display: block;
            animation: fadeInUp 0.4s ease;
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .tab-layout {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
            align-items: center;
        }

        .tab-text h3 {
            font-size: 2rem;
            font-weight: 800;
            margin-bottom: 1.5rem;
            color: #0F172A;
        }

        .tab-text p {
            font-size: 1rem;
            color: #475569;
            margin-bottom: 2rem;
            line-height: 1.8;
        }

        .feature-list {
            list-style: none;
        }

        .feature-list li {
            padding: 0.875rem 0;
            color: #0F172A;
            display: flex;
            align-items: flex-start;
            gap: 1rem;
            font-weight: 500;
            transition: all 0.3s ease;
        }

        .feature-list li:hover {
            padding-left: 0.5rem;
            color: #7C3AED;
        }

        .feature-list li:before {
            content: "✓";
            color: #7C3AED;
            font-weight: 800;
            font-size: 1.25rem;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            width: 24px;
            height: 24px;
            background: linear-gradient(135deg, rgba(124, 58, 237, 0.1), rgba(109, 40, 217, 0.1));
            border-radius: 6px;
        }

        .tab-illustration {
            background: linear-gradient(135deg, #F5F3FF 0%, #E9D5FF 100%);
            border-radius: 16px;
            padding: 3rem 2rem;
            text-align: center;
            min-height: 350px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 5rem;
            color: #7C3AED;
            border: 2px solid #E9D5FF;
            position: relative;
            overflow: hidden;
        }

        .tab-illustration::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(124, 58, 237, 0.08) 1px, transparent 1px);
            background-size: 30px 30px;
            animation: float 20s infinite linear;
            z-index: 1;
            pointer-events: none;
        }

        .tab-illustration span {
            position: relative;
            z-index: 2;
            animation: bounce 3s infinite ease-in-out;
        }

        @keyframes float {
            0% { transform: translate(0, 0); }
            100% { transform: translate(30px, 30px); }
        }

        @keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-20px); }
        }

        /* ===== FEATURES GRID ===== */
        .features-section {
            max-width: 1200px;
            margin: 5rem auto;
            padding: 4rem 2rem;
            background: linear-gradient(135deg, rgba(124, 58, 237, 0.05) 0%, rgba(109, 40, 217, 0.05) 100%);
            border-radius: 20px;
            border: 1px solid #E9D5FF;
        }

        .section-title {
            font-size: 2.5rem;
            font-weight: 800;
            text-align: center;
            margin-bottom: 3.5rem;
            color: #0F172A;
        }

        .features-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 2rem;
        }

        .feature-card {
            background: #ffffff;
            border-radius: 12px;
            padding: 2rem;
            border: 1px solid #E9D5FF;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
        }

        .feature-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, #7C3AED 0%, #6D28D9 100%);
            transform: scaleX(0);
            transform-origin: left;
            transition: transform 0.3s ease;
        }

        .feature-card:hover {
            box-shadow: 0 20px 40px rgba(124, 58, 237, 0.15);
            border-color: #D8BFD8;
            transform: translateY(-8px);
        }

        .feature-card:hover::before {
            transform: scaleX(1);
        }

        .feature-icon {
            width: 56px;
            height: 56px;
            background: linear-gradient(135deg, #F5F3FF 0%, #E9D5FF 100%);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.75rem;
            margin-bottom: 1.5rem;
            color: #7C3AED;
            border: 1px solid #E9D5FF;
            transition: all 0.3s ease;
        }

        .feature-card:hover .feature-icon {
            background: linear-gradient(135deg, #7C3AED 0%, #6D28D9 100%);
            color: #ffffff;
            transform: scale(1.1) rotate(5deg);
        }

        .feature-card h3 {
            font-size: 1.2rem;
            font-weight: 700;
            margin-bottom: 0.875rem;
            color: #0F172A;
        }

        .feature-card p {
            font-size: 0.95rem;
            color: #475569;
            line-height: 1.7;
        }

        /* ===== PROCESS SECTION ===== */
        .process-section {
            max-width: 1200px;
            margin: 5rem auto;
            padding: 0 2rem;
        }

        .process-title {
            font-size: 2.5rem;
            font-weight: 800;
            text-align: center;
            margin-bottom: 3.5rem;
            color: #0F172A;
        }

        .process-steps {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 2rem;
        }

        .process-step {
            text-align: center;
            position: relative;
            padding: 2rem 1.5rem;
            background: #ffffff;
            border-radius: 12px;
            border: 1px solid #E9D5FF;
            transition: all 0.3s ease;
        }

        .process-step:hover {
            background: linear-gradient(135deg, #F5F3FF 0%, #ffffff 100%);
            border-color: #D8BFD8;
            transform: translateY(-4px);
            box-shadow: 0 12px 24px rgba(124, 58, 237, 0.1);
        }

        .step-number {
            width: 64px;
            height: 64px;
            background: linear-gradient(135deg, #7C3AED 0%, #6D28D9 100%);
            color: #ffffff;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.75rem;
            font-weight: 800;
            margin: 0 auto 1.5rem;
            box-shadow: 0 8px 20px rgba(124, 58, 237, 0.3);
            transition: all 0.3s ease;
        }

        .process-step:hover .step-number {
            transform: scale(1.1);
            box-shadow: 0 12px 30px rgba(124, 58, 237, 0.4);
        }

        .process-step h3 {
            font-size: 1.2rem;
            font-weight: 700;
            margin-bottom: 0.75rem;
            color: #0F172A;
        }

        .process-step p {
            font-size: 0.95rem;
            color: #475569;
            line-height: 1.6;
        }

        .process-step:not(:last-child):after {
            content: "→";
            position: absolute;
            right: -1.5rem;
            top: 50%;
            transform: translateY(-50%);
            font-size: 1.5rem;
            color: #C084FC;
            font-weight: 700;
        }

        /* ===== CTA BANNER ===== */
        .cta-banner {
            background: linear-gradient(135deg, #7C3AED 0%, #6D28D9 100%);
            color: #ffffff;
            padding: 4rem 2rem;
            text-align: center;
            margin: 5rem auto;
            border-radius: 16px;
            max-width: 1200px;
            position: relative;
            overflow: hidden;
            box-shadow: 0 20px 50px rgba(124, 58, 237, 0.3);
        }

        .cta-banner::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 1px, transparent 1px);
            background-size: 50px 50px;
            animation: float 30s infinite linear;
            z-index: 0;
        }

        .cta-banner > * {
            position: relative;
            z-index: 2;
        }

        .cta-banner h2 {
            font-size: 2.5rem;
            font-weight: 800;
            margin-bottom: 1rem;
            letter-spacing: -0.5px;
        }

        .cta-banner p {
            font-size: 1.1rem;
            margin-bottom: 2rem;
            opacity: 0.95;
            font-weight: 400;
        }

        .cta-buttons-banner {
            display: flex;
            gap: 1.5rem;
            justify-content: center;
            flex-wrap: wrap;
        }

        .btn-light {
            background: #ffffff;
            color: #7C3AED;
            padding: 0.875rem 2rem;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-size: 0.95rem;
            font-weight: 700;
            text-decoration: none;
            transition: all 0.3s ease;
            display: inline-block;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        }

        .btn-light:hover {
            background: #F5F3FF;
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
        }

        .btn-light:active {
            transform: translateY(0);
        }

        /* ===== FOOTER ===== */
        footer {
            background: #0F172A;
            color: #ffffff;
            padding: 3.5rem 2rem;
            margin-top: 5rem;
            border-top: 1px solid #1E293B;
        }

        .footer-container {
            max-width: 1200px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 3rem;
            margin-bottom: 2rem;
        }

        .footer-section h3 {
            font-size: 1rem;
            font-weight: 700;
            margin-bottom: 1.25rem;
            color: #ffffff;
        }

        .footer-section p {
            color: #94A3B8;
            font-size: 0.9rem;
            line-height: 1.6;
        }

        .footer-section a {
            display: block;
            color: #94A3B8;
            text-decoration: none;
            margin-bottom: 0.75rem;
            transition: all 0.3s ease;
            font-weight: 500;
        }

        .footer-section a:hover {
            color: #7C3AED;
            padding-left: 0.5rem;
        }

        .footer-bottom {
            text-align: center;
            border-top: 1px solid #1E293B;
            padding-top: 2rem;
            color: #64748B;
            font-size: 0.9rem;
        }

        /* ===== RESPONSIVE ===== */
        @media (max-width: 1024px) {
            .tab-layout {
                grid-template-columns: 1fr;
                gap: 2.5rem;
            }

            .tab-illustration {
                min-height: 250px;
            }

            .features-grid {
                grid-template-columns: 1fr;
            }

            .process-steps {
                grid-template-columns: 1fr;
            }

            .process-step:not(:last-child):after {
                display: none;
            }
        }

        @media (max-width: 768px) {
            .nav-inner{padding:0 20px}
            .nav-links,.nav-right{display:none}
            .hamburger{display:flex}
            .nav.open .nav-links{display:flex;flex-direction:column;position:absolute;top:64px;left:0;right:0;background:#fff;height:auto;padding:12px 20px;box-shadow:0 12px 40px rgba(0,0,0,.1);border-bottom:1px solid #E2E8F0}
            .nav.open .nav-links>li{height:auto}
            .nav.open .nav-links>li>a{height:auto;padding:10px 0;border-bottom:none;margin-bottom:0;text-transform:none;letter-spacing:0;font-size:.95rem}
            .nav.open .nav-right{display:flex;position:absolute;left:0;right:0;background:#fff;padding:8px 20px 16px}
            .nav.open .nav-right .btn{flex:1;text-align:center}
            .mega-dd{position:static;opacity:1;visibility:visible;transform:none;box-shadow:none;border:none;border-bottom:none;pointer-events:auto;width:100%;margin-top:8px}
            .mega-inner{grid-template-columns:1fr;padding:16px 0;gap:16px}
            .mega-promo{display:none}
            .mega-cols{grid-template-columns:1fr;gap:16px}
            .mega-col-head{margin-bottom:8px}
            .mega-link{padding:6px 0}

            .hero {
                padding: 3.5rem 1.5rem 2.5rem;
            }

            .hero h1 {
                font-size: 2rem;
                margin-bottom: 1rem;
            }

            .hero p {
                font-size: 0.95rem;
            }

            .section-label {
                font-size: 0.7rem;
                padding: 0.4rem 0.75rem;
            }

            .tabs-section {
                margin: 3.5rem auto;
                padding: 0 1.5rem;
            }

            .tabs-header h2 {
                font-size: 1.75rem;
                margin-bottom: 2.5rem;
            }

            .tab-button {
                padding: 1rem 1.5rem;
                font-size: 0.9rem;
            }

            .tab-layout {
                gap: 2rem;
            }

            .tab-text h3 {
                font-size: 1.5rem;
                margin-bottom: 1rem;
            }

            .tab-text p {
                font-size: 0.95rem;
                margin-bottom: 1.5rem;
            }

            .tab-illustration {
                min-height: 280px;
                padding: 2rem 1.5rem;
            }

            .features-section {
                padding: 3.5rem 1.5rem;
                margin: 3.5rem auto;
            }

            .section-title {
                font-size: 1.75rem;
                margin-bottom: 2.5rem;
            }

            .features-grid {
                gap: 1.5rem;
            }

            .feature-card {
                padding: 1.75rem;
            }

            .feature-icon {
                width: 48px;
                height: 48px;
                font-size: 1.5rem;
                margin-bottom: 1rem;
            }

            .feature-card h3 {
                font-size: 1.05rem;
                margin-bottom: 0.75rem;
            }

            .feature-card p {
                font-size: 0.9rem;
            }

            .process-section {
                padding: 0 1.5rem;
                margin: 3.5rem auto;
            }

            .process-title {
                font-size: 1.75rem;
                margin-bottom: 2.5rem;
            }

            .process-steps {
                gap: 1.5rem;
            }

            .process-step {
                padding: 1.75rem 1.5rem;
            }

            .step-number {
                width: 56px;
                height: 56px;
                font-size: 1.5rem;
                margin-bottom: 1rem;
            }

            .process-step h3 {
                font-size: 1.05rem;
                margin-bottom: 0.5rem;
            }

            .process-step p {
                font-size: 0.9rem;
            }

            .cta-banner {
                padding: 2.5rem 1.5rem;
                margin: 3.5rem auto 0;
            }

            .cta-banner h2 {
                font-size: 1.75rem;
                margin-bottom: 1rem;
            }

            .cta-banner p {
                font-size: 0.95rem;
                margin-bottom: 1.5rem;
            }

            .cta-buttons-banner {
                flex-direction: column;
                gap: 1rem;
            }

            .btn-light {
                width: 100%;
                padding: 0.875rem 1.5rem;
                font-size: 0.9rem;
            }

            footer {
                padding: 2.5rem 1.5rem;
                margin-top: 3.5rem;
            }

            .footer-container {
                gap: 2rem;
                margin-bottom: 2rem;
            }

            .footer-section h3 {
                font-size: 0.95rem;
                margin-bottom: 1rem;
            }

            .footer-section p,
            .footer-section a {
                font-size: 0.85rem;
            }
        }

        @media (max-width: 480px) {
            .nav-inner {
                padding: 0 16px;
